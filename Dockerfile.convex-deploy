FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml convex.json ./
RUN pnpm install --frozen-lockfile

COPY convex ./convex

COPY scripts/resolve-convex-url.sh /usr/local/bin/resolve-convex-url.sh
COPY scripts/convex-deploy-entrypoint.sh /usr/local/bin/convex-deploy-entrypoint.sh
RUN chmod +x /usr/local/bin/resolve-convex-url.sh /usr/local/bin/convex-deploy-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/convex-deploy-entrypoint.sh"]
